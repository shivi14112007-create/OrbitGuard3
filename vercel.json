{
  "buildCommand": "bun run build",
  "outputDirectory": "dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/dist/server/index.mjs" }
  ],
  "functions": {
    "dist/server/index.mjs": {
      "runtime": "nodejs20.x",
      "includeFiles": "dist/**"
    }
  }
}